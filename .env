# =========================
# App
# =========================
NODE_ENV=development
PORT=3000

# =========================
# CORS
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# =========================
# PostgreSQL (default runtime)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_db
DB_MAX_CONNECTIONS=20
USE_SSL=false

# =========================
# PostgreSQL (tests)
# =========================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=app_db_test

# =========================
# Azure SQL Database
# =========================
AZURE_SQL_SERVER=my-azure-sql-server.database.windows.net
AZURE_SQL_DATABASE=example_azure_db
AZURE_SQL_USER=azure_user
AZURE_SQL_PASSWORD=SuperSecretPassword123
AZURE_SQL_PORT=1433
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false

HELIOS_API_KEY=key_f600a15d-1a84-4af8-b8b7-046b68b3bf13
SIC_COGNITO_USER_POOL_ID=us-east-1_DQSYCcjSZ
HELIOS_WEB_COGNITO_USER_POOL_ID=us-east-1_WU6fgdUg3


# Migrations
RUN_MIGRATIONS=true
